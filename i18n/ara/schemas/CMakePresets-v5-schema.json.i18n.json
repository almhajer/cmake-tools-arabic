	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.properties.CMAKE_BUILD_TYPE.anyOf.3": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.0": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.1": "قيمة منطقية تمثل قيمة المتغير. أي ما يعادل \"صحيح\" أو \"خطأ\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.2": "سلسلة تمثل قيمة المتغير (تدعم التوسع الكلي).",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.3": "الكائن الذي يمثل نوع وقيمة المتغير.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.3.properties.type": "سلسلة اختيارية تمثل نوع المتغير. يجب أن يكون BOOL أو FILEPATH أو PATH أو STRING أو INTERNAL.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.3.properties.value.anyOf.0": "القيمة المنطقية المطلوبة التي تمثل قيمة المتغير. أي ما يعادل \"صحيح\" أو \"خطأ\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.additionalProperties.anyOf.3.properties.value.anyOf.1": "السلسلة المطلوبة التي تمثل قيمة المتغير. يدعم هذا الحقل التوسع الكلي.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.environment": "التعيين الاختياري لمتغيرات البيئة. المفتاح هو اسم المتغير (الذي يجب ألا يكون سلسلة فارغة). يتم تعيين كافة المتغيرات، بغض النظر عما إذا كانت بيئة العملية قد خصصت لها قيمة أم لا. يدعم هذا الحقل توسيع الماكرو، ويمكن لمتغيرات البيئة في التعيين أن تشير إلى بعضها البعض ويتم إدراجها بأي ترتيب، طالما أن هذه المراجع لا تنشئ حلقة (على سبيل المثال، إذا كان ENV_1 هو $env{ENV_2}، فلا يمكن أن يكون ENV_2 هو $env{ENV_1}). يتم توريث متغيرات البيئة من خلال حقل الوراثة وستكون بيئة الإعداد المسبق عبارة عن اتحاد بيئتها الخاصة وبيئة جميع أصولها. إذا كانت الإعدادات المسبقة الموحدة المتعددة تحدد نفس المتغير، فسيتم تطبيق قواعد الوراثة القياسية. يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.environment.additionalProperties.anyOf.0": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.environment.additionalProperties.anyOf.1": "سلسلة تمثل قيمة المتغير.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings": "كائن اختياري يحدد التحذيرات.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings.properties.dev": "قيمة منطقية اختيارية. أي ما يعادل تمرير -Wdev أو -Wno-dev في سطر الأوامر. لا يمكن ضبطه على \"خطأ\" إذا تم ضبط Errors.dev على \"صحيح\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings.properties.deprecated": "قيمة منطقية اختيارية. وهذا يعادل تمرير -Wdeprecated أو -Wno-deprecated في سطر الأوامر. لا يمكن ضبطه على \"خطأ\" إذا تم ضبط \"errors.deprecated\" على \"صحيح\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings.properties.uninitialized": "قيمة منطقية اختيارية. إن تعيينه على \"صحيح\" يعادل تمرير --warn-uninitialized في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings.properties.unusedCli": "قيمة منطقية اختيارية. تعيينه على خطأ يعادل تمرير --no-warn-unused-cli في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.warnings.properties.systemVars": "قيمة منطقية اختيارية. تعيينه على \"صحيح\" يعادل تمرير --check-system-vars في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.errors": "كائن اختياري يحدد الأخطاء.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.errors.properties.dev": "قيمة منطقية اختيارية. أي ما يعادل تمرير -Werror=dev أو -Wno-error=dev في سطر الأوامر. لا يمكن ضبطه على \"صحيح\" إذا تم ضبط \"warnings.dev\" على \"خطأ\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.errors.properties.deprecated": "قيمة منطقية اختيارية. وهذا يعادل تمرير -Werror=deprecated أو -Wno-error=deprecated في سطر الأوامر. لا يمكن ضبطه على \"صحيح\" إذا تم ضبط \"التحذيرات.deprecated\" على \"خطأ\".",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.debug": "كائن اختياري يحدد خيارات التصحيح.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.debug.properties.output": "قيمة منطقية اختيارية. إن تعيينه على \"صحيح\" يعادل تمرير -debug-output في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.debug.properties.tryCompile": "قيمة منطقية اختيارية. إن تعيينه على \"صحيح\" يعادل تمرير -debug-trycompile في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.debug.properties.find": "قيمة منطقية اختيارية. إن تعيينه على \"صحيح\" يعادل تمرير -debug-find في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.installDir": "سلسلة اختيارية تمثل المسار إلى دليل التثبيت. يدعم هذا الحقل التوسع الكلي. إذا تم تحديد مسار نسبي، فسيتم حسابه بالنسبة إلى الدليل المصدر.",
	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.toolchainFile": "سلسلة اختيارية تمثل المسار إلى ملف سلسلة الأدوات. يدعم هذا الحقل التوسع الكلي. إذا تم تحديد مسار نسبي، فسيتم حسابه بالنسبة إلى دليل البناء، وإذا لم يتم العثور عليه، فسيتم حسابه بالنسبة إلى الدليل المصدر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets": "مجموعة اختيارية من كائنات البناء المسبقة. يستخدم لتحديد الوسائط في cmake --build. متوفر في الإصدار 2 والإصدارات الأحدث.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.name": "السلسلة المطلوبة التي تمثل الاسم المناسب للآلة للإعداد المسبق. يتم استخدام هذا المعرف في الوسيطة --preset. لا ينبغي أن يكون هناك إعدادان مسبقان (التكوين أو البناء أو الاختبار) عند تقاطع CMakePresets.json و CMakeUserPresets.json في نفس الدليل وبنفس الاسم.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.hidden": "قيمة منطقية اختيارية تحدد ما إذا كان يجب إخفاء الإعداد المسبق أم لا. إذا كان الإعداد المسبق مخفيًا، فلا يمكن استخدامه في الوسيطة --preset، ولن يتم عرضه في واجهة المستخدم الرسومية CMake، ولا يحتاج إلى قيمة configPreset صالحة، حتى من الميراث. تم تصميم الإعدادات المسبقة المخفية لاستخدامها كأساس للإعدادات المسبقة الأخرى الموروثة من خلال حقل الوراثة.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.inherits.anyOf.0": "سلسلة اختيارية تمثل اسم الإعداد المسبق للبناء المراد توريثه.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.inherits.anyOf.1": "مجموعة اختيارية من السلاسل التي تمثل أسماء إعدادات البناء المسبقة المراد توريثها. سوف يرث الإعداد المسبق جميع الحقول من الإعدادات المسبقة الوراثة افتراضيًا (باستثناء الاسم، والمخفي، والوراثة، والوصف، واسم العرض)، ولكن يمكنك تجاوزها كيفما تشاء. إذا كانت الإعدادات المسبقة الموروثة المتعددة توفر قيمًا متعارضة لنفس الحقل، فسيتم تفضيل الإعداد المسبق السابق في قائمة العناصر الموروثة. الإعدادات المسبقة لـ CMakePresets.json يجب ألا ترث من الإعدادات المسبقة لـ CMakeUserPresets.json.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.inherits.anyOf.1.items": "سلسلة اختيارية تمثل اسم الإعداد المسبق المراد توريثه.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.configurePreset": "سلسلة اختيارية تحدد اسم الإعداد المسبق للتكوين الذي سيتم ربطه بإعداد البناء المسبق هذا. إذا لم يتم تحديدconfigPreset، فيجب أن يتم توريثه من الإعداد المسبق الوراثي (ما لم يتم إخفاؤه). يتم استنتاج دليل شجرة البناء من قيمة التكوين المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.vendor": "مهمة اختيارية تحتوي على معلومات خاصة بالمزود. لا يقوم CMake بتفسير محتويات هذا الحقل، باستثناء التحقق من أنه عبارة عن تعيين، إذا كان موجودًا. ومع ذلك، يجب أن يتبع نفس الاصطلاحات التي يتبعها حقل الموفر على مستوى الجذر. إذا استخدم الموفرون حقل الموفر الخاص بهم حسب القيمة المحددة مسبقًا، فيجب عليهم تنفيذ التوريث بطريقة معقولة، إن أمكن.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.displayName": "سلسلة اختيارية باسم وصفي للقيمة المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.description": "سلسلة اختيارية مع وصف بسيط للقيمة المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.inheritConfigureEnvironment": "قيمة منطقية اختيارية تكون قيمتها الافتراضية صحيحة. إذا كان صحيحًا، فسيتم توريث متغيرات البيئة الخاصة بالإعداد المسبق للتكوين المرتبط بعد كافة إعدادات البناء المسبقة الموروثة، ولكن قبل تحديد متغيرات البيئة بشكل صريح في الإعداد المسبق للإصدار هذا.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.environment": "التعيين الاختياري لمتغيرات البيئة. المفتاح هو اسم المتغير (الذي يجب ألا يكون سلسلة فارغة). يتم تعيين كافة المتغيرات، بغض النظر عما إذا كانت بيئة العملية قد خصصت لها قيمة أم لا. يدعم هذا الحقل توسيع الماكرو، ويمكن لمتغيرات البيئة في التعيين أن تشير إلى بعضها البعض ويتم إدراجها بأي ترتيب، طالما أن هذه المراجع لا تنشئ حلقة (على سبيل المثال، إذا كان ENV_1 هو $env{ENV_2}، فلا يمكن أن يكون ENV_2 هو $env{ENV_1}). يتم توريث متغيرات البيئة من خلال حقل الوراثة وستكون بيئة الإعداد المسبق عبارة عن اتحاد بيئتها الخاصة وبيئة جميع أصولها. إذا كانت الإعدادات المسبقة الموحدة المتعددة تحدد نفس المتغير، فسيتم تطبيق قواعد الوراثة القياسية. يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.environment.additionalProperties.anyOf.0": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.environment.additionalProperties.anyOf.1": "سلسلة تمثل قيمة المتغير.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.jobs": "عدد صحيح اختياري. أي ما يعادل تمرير --parallel أو -j في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.targets.anyOf.0": "سلسلة اختيارية. أي ما يعادل تمرير --target أو -t في سطر الأوامر. يمكن للموفرين تجاهل خاصية الأهداف أو إخفاء إعدادات البناء المسبقة التي تحدد الأهداف بشكل صريح.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.targets.anyOf.1": "مجموعة سلسلة اختيارية. أي ما يعادل تمرير --target أو -t في سطر الأوامر. يمكن للموفرين تجاهل خاصية الأهداف أو إخفاء إعدادات البناء المسبقة التي تحدد الأهداف بشكل صريح.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.targets.anyOf.1.items": "سلسلة اختيارية. أي ما يعادل تمرير --target أو -t في سطر الأوامر. يمكن للموفرين تجاهل خاصية الأهداف أو إخفاء إعدادات البناء المسبقة التي تحدد الأهداف بشكل صريح.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.configuration": "سلسلة اختيارية. إنه يعادل تمرير --config في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.cleanFirst": "قيمة منطقية اختيارية. إذا كان هذا صحيحًا، فهذا يعادل تمرير --clean-first في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.resolvePackageReferences": "سلسلة اختيارية تحدد سلوك دقة الحزمة. القيم الصالحة هي \"on\" (يتم حل الحزم قبل التجميع)، و\"off\" (لم يتم حل الحزم قبل التجميع)، و\"فقط\" (يتم حل الحزم، ولكن لن يتم تنفيذ أي تجميع).",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.verbose": "قيمة منطقية اختيارية. إذا كان صحيحًا، فهو يعادل تمرير --verbose في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.nativeToolOptions": "مجموعة سلسلة اختيارية. أي ما يعادل تمرير الخيارات بعد - في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.buildPresets.items.properties.nativeToolOptions.items": "سلسلة اختيارية تمثل خيارًا سيتم تمريره بعد -- في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets": "مجموعة اختيارية من كائنات الاختبار المعدة مسبقًا. يستخدم لتحديد الوسائط في ctest. متوفر في الإصدار 2 والإصدارات الأحدث.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.name": "السلسلة المطلوبة التي تمثل الاسم المناسب للآلة للإعداد المسبق. يتم استخدام هذا المعرف في الوسيطة --preset. لا ينبغي أن يكون هناك إعدادان مسبقان (التكوين أو البناء أو الاختبار) عند تقاطع CMakePresets.json و CMakeUserPresets.json في نفس الدليل وبنفس الاسم.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.hidden": "قيمة منطقية اختيارية تحدد ما إذا كان يجب إخفاء الإعداد المسبق أم لا. إذا كان الإعداد المسبق مخفيًا، فلا يمكن استخدامه في الوسيطة --preset، ولن يتم عرضه في واجهة المستخدم الرسومية CMake، ولا يحتاج إلى قيمة configPreset صالحة، حتى من الميراث. تم تصميم الإعدادات المسبقة المخفية لاستخدامها كأساس للإعدادات المسبقة الأخرى الموروثة من خلال حقل الوراثة.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.inherits.anyOf.0": "سلسلة اختيارية تمثل اسم الإعداد المسبق للاختبار المراد توريثه.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.inherits.anyOf.1": "مجموعة اختيارية من السلاسل التي تمثل أسماء إعدادات الاختبار المسبقة المراد توريثها. سوف يرث الإعداد المسبق جميع الحقول من الإعدادات المسبقة الوراثة افتراضيًا (باستثناء الاسم، والمخفي، والوراثة، والوصف، واسم العرض)، ولكن يمكنك تجاوزها كيفما تشاء. إذا كانت الإعدادات المسبقة الموروثة المتعددة توفر قيمًا متعارضة لنفس الحقل، فسيتم تفضيل الإعداد المسبق السابق في قائمة العناصر الموروثة. الإعدادات المسبقة لـ CMakePresets.json يجب ألا ترث من الإعدادات المسبقة لـ CMakeUserPresets.json.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.inherits.anyOf.1.items": "سلسلة اختيارية تمثل اسم الإعداد المسبق المراد توريثه.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.configurePreset": "سلسلة اختيارية تحدد اسم الإعداد المسبق للتكوين الذي سيتم ربطه بهذا الإعداد المسبق للاختبار. إذا لم يتم تحديدconfigPreset، فيجب أن يتم توريثه من الإعداد المسبق الوراثي (ما لم يتم إخفاؤه). يتم استنتاج دليل شجرة البناء من قيمة التكوين المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.vendor": "مهمة اختيارية تحتوي على معلومات خاصة بالمزود. لا يقوم CMake بتفسير محتويات هذا الحقل، باستثناء التحقق من أنه عبارة عن تعيين، إذا كان موجودًا. ومع ذلك، يجب أن يتبع نفس الاصطلاحات التي يتبعها حقل الموفر على مستوى الجذر. إذا استخدم الموفرون حقل الموفر الخاص بهم حسب القيمة المحددة مسبقًا، فيجب عليهم تنفيذ التوريث بطريقة معقولة، إن أمكن.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.displayName": "سلسلة اختيارية باسم وصفي للقيمة المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.description": "سلسلة اختيارية مع وصف بسيط للقيمة المحددة مسبقًا.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.inheritConfigureEnvironment": "قيمة منطقية اختيارية تكون قيمتها الافتراضية صحيحة. إذا كان صحيحًا، فسيتم توريث متغيرات البيئة الخاصة بالإعداد المسبق للتكوين المرتبط بعد كافة إعدادات الاختبار المسبقة الموروثة، ولكن قبل متغيرات البيئة المحددة صراحةً في هذا الإعداد المسبق للاختبار.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.environment": "التعيين الاختياري لمتغيرات البيئة. المفتاح هو اسم المتغير (الذي يجب ألا يكون سلسلة فارغة). يتم تعيين كافة المتغيرات، بغض النظر عما إذا كانت بيئة العملية قد خصصت لها قيمة أم لا. يدعم هذا الحقل توسيع الماكرو، ويمكن لمتغيرات البيئة في التعيين أن تشير إلى بعضها البعض ويتم إدراجها بأي ترتيب، طالما أن هذه المراجع لا تنشئ حلقة (على سبيل المثال، إذا كان ENV_1 هو $env{ENV_2}، فلا يمكن أن يكون ENV_2 هو $env{ENV_1}). يتم توريث متغيرات البيئة من خلال حقل الوراثة وستكون بيئة الإعداد المسبق عبارة عن اتحاد بيئتها الخاصة وبيئة جميع أصولها. إذا كانت الإعدادات المسبقة الموحدة المتعددة تحدد نفس المتغير، فسيتم تطبيق قواعد الوراثة القياسية. يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.environment.additionalProperties.anyOf.0": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.environment.additionalProperties.anyOf.1": "سلسلة تمثل قيمة المتغير.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.configuration": "سلسلة اختيارية. وهو يعادل تمرير --build-config في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.overwriteConfigurationFile": "مجموعة اختيارية من خيارات التكوين لتجاوز الخيارات المحددة في ملف التكوين CTest. وهو يعادل تمرير ``--overwrite`` لكل قيمة من القيم الموجودة في المصفوفة.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.overwriteConfigurationFile.items": "خيار مكتوب كزوج مفاتيح-valor بالتنسيق \"مفتاح=قيمة\".",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output": "كائن اختياري يحدد خيارات الإخراج.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.shortProgress": "قيمة منطقية اختيارية. إذا كان صحيحًا، فهو يعادل تمرير --progress في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.verbosity": "سلسلة اختيارية تحدد مستوى التفاصيل. القيم الصالحة هي \"افتراضية\" (أي ما يعادل تمرير أي مستوى من إشارات الإسهاب في سطر الأوامر)، و\"مطول\" (أي ما يعادل تمرير --verbose في سطر الأوامر)، و\"إضافية\" (أي ما يعادل تمرير --extra-verbose في سطر الأوامر).",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.debug": "قيمة منطقية اختيارية. إذا كان صحيحًا، فهذا يعادل تمرير --debug في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.outputOnFailure": "قيمة منطقية اختيارية. إذا كان هذا صحيحًا، فهذا يعادل تمرير --output-on-failure في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.quiet": "قيمة منطقية اختيارية. إذا كان صحيحًا، فهو يعادل تمرير --quiet في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.outputLogFile": "سلسلة اختيارية تحدد المسار إلى ملف السجل. أي ما يعادل تمرير --output-log في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.labelSummary": "قيمة منطقية اختيارية. إذا كان خطأ، فهو يعادل تمرير --no-label-summary في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.subprojectSummary": "قيمة منطقية اختيارية. إذا كان خطأ، فهو يعادل تمرير --no-subproject-summary في سطر الأوامر.",
	"schemas/CMakePresets-v5-schema.json.properties.testPresets.items.properties.output.properties.maxPassedTestOutputSize": "عدد صحيح اختياري يحدد الحد الأقصى لحجم مخرجات الاختبارات التي تم تمريرها بالبايت. إنه يعادل اجتياز --test-output-size-passed في سطر الأوامر.",
