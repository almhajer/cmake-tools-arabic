	"schemas/CMakePresets-v5-schema.json.properties.configurePresets.items.properties.cacheVariables.properties.CMAKE_TOOLCHAIN_FILE.anyOf.1": "يؤدي تعيين متغير إلى NULL إلى أن يكون غير محدد، حتى لو تم وراثة قيمة من إعداد مسبق آخر.",
